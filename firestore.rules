rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sellers/{sellerId} {
      allow read: if true;
      allow write: if request.auth.uid == sellerId;

      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if request.auth.uid == sellerId;
      }

      match /orders/{orderId} {
        allow read: if request.auth.uid == sellerId;
        allow create: if request.auth != null;
        allow update: if request.auth.uid == sellerId;
      }

      match /messages/{messageId} {
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.receiverUid == sellerId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;
        allow read: if request.auth.uid == sellerId
          || (request.auth != null && resource.data.senderUid == request.auth.uid);
        allow update: if request.auth.uid == sellerId;
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if false;
      }
    }

  }
}
