rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sellers collection - public store data is readable by everyone,
    // owner writes are still restricted to the signed-in seller.
    match /sellers/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
      
      // Sellers' products - public read, owner write
      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if request.auth.uid == userId;
      }
      
      // Sellers' orders - owner read/write, buyers can create
      match /orders/{orderId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update: if request.auth.uid == userId;
      }

      // Messages - authenticated users can send messages, sellers can read their own inbox
       match /sellers/{sellerid}/messages/{messageId} {
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.receiverUid is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;

        allow read: if request.auth != null
        && (resource.data.senderUid == request.auth.uid
        || resource.data.receiverUid == request.auth.uid);
      }
    }
  }
}
