rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sellers collection - public store data is readable by everyone,
    // owner writes are still restricted to the signed-in seller.
    match /sellers/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
      
      // Sellers' products - public read, owner write
      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if request.auth.uid == userId;
      }
      
      // Sellers' orders - owner read/write, buyers can create
      match /orders/{orderId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update: if request.auth.uid == userId;
      }
    }
  }
}
